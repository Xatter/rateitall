{
  "manifest_version": 3,
  "name": "Mr. Rate It All",
  "description": "Rate anything you can select on any website",
  "author": "Jim Wallace",
  "version": "0.2.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "Rate It!"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "./static/js/content.js"
      ],
      "all_frames": false,
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "./static/js/background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "webNavigation"
  ]
}
